# Copy this file to .env and fill in real values. Never commit .env.
#
# Basic auth credential for the staging reports API, base64-encoded
# "username:password" — do NOT include the "Basic " prefix, proxy.conf.js
# prepends it.
API_BASIC_AUTH=

# The fitness centre id to scope every report request to (e.g. 38).
FITNESS_CENTER_ID=
